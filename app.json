{
  "name": "AgentSite",
  "description": "AI-powered website builder using multi-agent orchestration",
  "repository": "https://github.com/jhd3197/AgentSite",
  "logo": "",
  "keywords": ["ai", "agents", "website-builder", "fastapi", "python"],
  "stack": "container",
  "env": {
    "AGENTSITE_DEFAULT_MODEL": {
      "description": "Default LLM model for all agents (provider/model format)",
      "value": "openai/gpt-4o"
    },
    "OPENAI_API_KEY": {
      "description": "OpenAI API key",
      "required": false
    },
    "CLAUDE_API_KEY": {
      "description": "Anthropic Claude API key",
      "required": false
    },
    "GOOGLE_API_KEY": {
      "description": "Google AI API key",
      "required": false
    },
    "GROQ_API_KEY": {
      "description": "Groq API key",
      "required": false
    },
    "GROK_API_KEY": {
      "description": "Grok API key",
      "required": false
    },
    "OPENROUTER_API_KEY": {
      "description": "OpenRouter API key",
      "required": false
    }
  },
  "formation": {
    "web": {
      "quantity": 1,
      "size": "basic"
    }
  }
}
